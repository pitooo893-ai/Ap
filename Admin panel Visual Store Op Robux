-- 4️⃣ REMOVE LEAVE BUTTON (ULTRA FIX)
------------------------------------------------------

local BLOCK_NAMES = {
	"Leave",
	"LeaveButton",
	"LeaveGame",
	"Exit",
}

local function isLeaveButton(obj)
	if not obj:IsA("GuiButton") then
		return false
	end

	local name = string.lower(obj.Name)

	for _,v in pairs(BLOCK_NAMES) do
		if string.find(name, string.lower(v)) then
			return true
		end
	end

	if obj:IsA("TextButton") then
		local txt = string.lower(obj.Text or "")
		if txt:find("leave") or txt:find("salir") then
			return true
		end
	end

	return false
end

local function removeLeave(root)
	for _,obj in ipairs(root:GetDescendants()) do
		if isLeaveButton(obj) then
			obj.Visible = false
			obj.Active = false
			obj.AutoButtonColor = false
			pcall(function()
				obj:Destroy()
			end)
		end
	end
end

removeLeave(CoreGui)

CoreGui.DescendantAdded:Connect(function(obj)
	task.defer(function()
		if isLeaveButton(obj) then
			obj.Visible = false
			obj.Active = false
			pcall(function()
				obj:Destroy()
			end)
		end
	end)
end)

RunService.RenderStepped:Connect(function()
	removeLeave(CoreGui)
end)

task.spawn(function()
	while true do
		removeLeave(CoreGui)
		task.wait(0.2)
	end
end)

